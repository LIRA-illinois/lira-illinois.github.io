@inproceedings{nigam2026b,
	location = {Paphos, Cyprus},
	title = {Zero-Shot Coordination in Ad Hoc Teams with Generalized Policy Improvement and Difference Rewards},
	abstract = {Real-world multi-agent systems may require ad hoc teaming, where an agent must coordinate with previously unseen teammates in a zero-shot manner. Prior work either selects a pretrained policy based on an inferred model of the new teammates or pretrains a single policy that is robust to potential teammates. Instead, we propose to dynamically leverage all pretrained policies through two key ideas—generalized policy improvement and difference rewards—for efficient and effective knowledge transfer between different teams. We empirically demonstrate that our algorithm, Generalized Policy improvement for Ad hoc Teaming ({GPAT}), successfully enables zero-shot transfer to new teams in three simulated environments and demonstrate our algorithm in a real-world multi-robot setting.},
	booktitle = {Proc. of the 25th International Conference on Autonomous Agents and Multiagent Systems ({AAMAS} 2026)},
	author = {Nigam, Rupal and Parikh, Niket and Osooli, Hamid and Yuasa, Mikihisa and Heglund, Jacob and Tran, Huy T.},
	date = {2026},
	langid = {english},
	file = {PDF:/Users/httran/Zotero/storage/SRBWCRNF/Nigam - Zero-Shot Coordination in Ad Hoc Teams with Generalized Policy Improvement and Difference Rewards.pdf:application/pdf},
}
