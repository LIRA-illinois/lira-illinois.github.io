---
import { Icon } from "astro-icon/components";
import Logo from "./Logo.astro";
import SocialLink from "./SocialLink.astro";

const today = new Date();
---

<footer>
  <div class="footer-logo">
    <Logo />
  </div>
  <div class="social-links">
    <SocialLink
      href="mailto:huytran1@illinois.edu"
      srText="Email us"
      iconName="envelope-solid-full"
    />
    <SocialLink
      href="https://scholar.google.com/citations?user=TgaPukcAAAAJ&hl=en"
      srText="Visit our Google Scholar profile"
      iconName="google-scholar-brands-solid-full"
    />
    <SocialLink
      href="https://github.com/lira-illinois"
      srText="Visit our GitHub repo"
      iconName="github-brands-solid-full"
    />
  </div>
  <div class="copyright">
    &copy; {today.getFullYear()} Huy T. Tran. Powered by <a
      href="https://astro.build"
      target="_blank"
      rel="noopener">Astro</a
    >.
  </div>
</footer>
<style>
  footer {
    align-items: center;
    color: var(--secondary-color);
    display: grid;
    gap: 1em;
    grid-template-columns: 1fr auto 1fr;
    margin: 0em auto;
    max-width: var(--large-width);
    padding: 6em 0em 2em 0em;
  }
  footer a {
    color: var(--secondary-color);
  }
  footer a:hover {
    color: var(--focus-color);
  }
  .footer-logo {
    justify-self: start;
  }
  .social-links {
    display: flex;
    justify-content: center;
  }
  .copyright {
    justify-self: end;
    text-align: right;
  }

  @media (max-width: 820px) {
    footer {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
    }
    .footer-logo,
    .copyright {
      justify-self: center;
      text-align: center;
    }
  }
</style>
