---
import Logo from "./Logo.astro";
import Nav from "./Nav.astro";
---

<header>
  <Logo />
  <Nav />
</header>
<style>
  header {
    align-items: center;
    display: flex;
    margin: 0 auto;
    max-width: var(--large-width);
    padding: 0em 0em 6em 0em;
  }
  @media screen and (max-width: 820px) {
    .logo {
      display: none;
    }
  }
</style>
