---
import HeaderLink from "./HeaderLink.astro";
---

<nav class="site-nav">
  <button
    class="menu-button"
    aria-expanded="false"
    aria-controls="primary-menu"
    type="button"
  >
    <span class="sr-only">Menu</span>
  </button>
  <div id="primary-menu" class="menu-links" data-open="false">
    <HeaderLink href="/">Home</HeaderLink>
    <HeaderLink href="/team">Team</HeaderLink>
    <HeaderLink href="/research">Research</HeaderLink>
    <HeaderLink href="/publications">Publications</HeaderLink>
    <HeaderLink href="/news">News</HeaderLink>
  </div>
</nav>

<script>
  const nav = document.querySelector(".site-nav");
  const button = nav?.querySelector<HTMLButtonElement>(".menu-button");
  const menu = nav?.querySelector<HTMLDivElement>(".menu-links");
  const menuLinks = menu?.querySelectorAll("a");

  const closeMenu = () => {
    if (!button || !menu) return;
    button.setAttribute("aria-expanded", "false");
    menu.setAttribute("data-open", "false");
  };

  button?.addEventListener("click", () => {
    if (!button || !menu) return;
    const isOpen = button.getAttribute("aria-expanded") === "true";
    button.setAttribute("aria-expanded", String(!isOpen));
    menu.setAttribute("data-open", String(!isOpen));
  });

  menuLinks?.forEach((link) => {
    link.addEventListener("click", () => {
      closeMenu();
    });
  });

  document.addEventListener("click", (event) => {
    if (!nav || !button) return;
    const target = event.target;
    if (!(target instanceof Node)) return;
    const clickedInsideNav = nav.contains(target);
    const isOpen = button.getAttribute("aria-expanded") === "true";
    if (!clickedInsideNav && isOpen) {
      closeMenu();
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeMenu();
      button?.focus();
    }
  });

  window.addEventListener("resize", () => {
    if (window.innerWidth > 820) {
      closeMenu();
    }
  });
</script>

<style>
  .site-nav {
    align-items: center;
    display: flex;
    flex: 1;
    justify-content: flex-end;
    position: relative;
  }

  .menu-button {
    align-items: center;
    background: transparent;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    display: none;
    height: 2.25rem;
    justify-content: center;
    padding: 0;
    position: relative;
    width: 2.5rem;
  }

  .menu-button::before,
  .menu-button::after {
    background-color: var(--secondary-color);
    border-radius: 999px;
    content: "";
    height: 2px;
    left: 50%;
    position: absolute;
    transform: translateX(-50%);
    width: 1.4rem;
  }

  .menu-button::before {
    top: 0.8rem;
  }

  .menu-button::after {
    top: 1.35rem;
  }

  .menu-button:hover::before,
  .menu-button:hover::after {
    background-color: var(--focus-color);
  }

  .menu-button:focus-visible {
    outline: 2px solid var(--supporting-color);
    outline-offset: 2px;
  }

  .menu-links {
    align-items: center;
    display: flex;
    justify-content: flex-end;
  }

  @media (max-width: 820px) {
    /* .site-nav {
      justify-content: flex-end;
    } */

    .menu-button {
      display: inline-block;
    }

    .menu-links {
      background: var(--background-color);
      border: 1px solid var(--secondary-color-light);
      border-radius: 8px;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
      display: none;
      flex-direction: column;
      min-width: 13rem;
      padding: 0.8rem;
      position: absolute;
      right: 0;
      top: calc(100% + 0.6rem);
      z-index: 20;
    }

    .menu-links[data-open="true"] {
      display: flex;
    }

    .menu-links :global(a) {
      padding: 0.5rem 0;
      width: 100%;
    }
  }

  @media (min-width: 821px) {
    .menu-links {
      display: flex !important;
    }
  }
</style>
